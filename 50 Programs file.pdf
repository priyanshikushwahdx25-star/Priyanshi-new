using namespace std;

int add(int a, int b = 10) {
    return a + b;
}

int main() {
    cout << add(5) << endl;
    cout << add(5, 20);
}
Output:

15
25
7. Constant Arguments
C++
#include <iostream>
using namespace std;

void show(const int x) {
    // x = x + 1; // not allowed
    cout << x;
}

int main() {
    int a = 10;
    show(a);
