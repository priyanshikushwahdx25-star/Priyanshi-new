    s.display();
}
Output:

1 Priyanshi
12. Member Functions Inside & Outside Class
C++
#include <iostream>
using namespace std;

class Demo {
public:
    void show(); // declaration
};

void Demo::show() { // outside definition
    cout << "Function defined outside class";
}

int main() {
    Demo d;
    d.show();
}
Output:

Function defined outside class
13. Nesting of Member Functions
C++
#include <iostream>
using namespace std;

class Nest {
    int a, b;
public:
    void input() {
        a = 5; b = 10;
    }
    void sum() {
        cout << "Sum: " << a + b;
    }
    void display() {
        input();
        sum();
    }
};

int main() {
    Nest n;
    n.display();
}
Output:

Sum: 15
