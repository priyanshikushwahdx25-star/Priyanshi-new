15. Array in Class (Marks)
C++
#include <iostream>
using namespace std;

class Marks {
    int m[3];
public:
    void input() {
        m[0]=80; m[1]=85; m[2]=90;
    }
    void display() {
        cout << "Marks: ";
        for(int i=0;i<3;i++)
            cout << m[i] << " ";
    }
};

int main() {
    Marks obj;
    obj.input();
    obj.display();
}
Output:

Marks: 80 85 90

16. Memory allocation for objects
C++
#include <iostream>
using namespace std;

class Test {
public:
    int x;
    void show() {
        cout << "Value: " << x << endl;
    }
};

int main() {
    Test *t = new Test;   // dynamic allocation
    t->x = 10;
    t->show();
    delete t;
    return 0;
}
Output:

Value: 10
17. Static data member & static function
C++
#include <iostream>
using namespace std;

class Demo {
public:
    static int count;

    Demo() { count++; }

    static void showCount() {
        cout << "Count: " << count << endl;
    }
};

int Demo::count = 0;

int main() {
    Demo d1, d2, d3;
    Demo::showCount();
}
Output:

Count: 3
18. Array of objects
C++
#include <iostream>
using namespace std;

class Student {
public:
    int id;
    void get() {
        cin >> id;
    }
    void show() {
        cout << "ID: " << id << endl;
    }
};

int main() {
    Student s[3];

    for(int i=0;i<3;i++) s[i].get();
    for(int i=0;i<3;i++) s[i].show();
}
Output:

Input: 1 2 3
ID: 1
ID: 2
ID: 3
