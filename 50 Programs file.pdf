1. Function Prototype and Definition
C++
#include <iostream>
using namespace std;

void greet(); // prototype

int main() {
    greet();
    return 0;
}

void greet() { // definition
    cout << "Hello, this is function definition!";
}
Output:

Hello, this is function definition!
2. Call by Value and Call by Reference
C++
#include <iostream>
using namespace std;

void callByValue(int x) {
    x = x + 10;
}

void callByReference(int &y) {
    y = y + 10;
}

int main() {
    int a = 5, b = 5;

    callByValue(a);
    callByReference(b);

    cout << "Call by Value: " << a << endl;
    cout << "Call by Reference: " << b;
}
Output:

Call by Value: 5
Call by Reference: 15
3. Swap using Pointers
C++
#include <iostream>
using namespace std;

void swap(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

int main() {
    int x = 10, y = 20;

    swap(&x, &y);

    cout << "After swap: " << x << " " << y;
}
Output:

After swap: 20 10
4. Return by Reference
C++
#include <iostream>
using namespace std;

int& func(int &x) {
    return x;
}

int main() {
    int a = 10;
    func(a) = 50;

    cout << "Value of a: " << a;
}
Output:

Value of a: 50
5. Inline Function (Square)
C++
#include <iostream>
using namespace std;

inline int square(int x) {
    return x * x;
}

int main() {
    cout << "Square: " << square(5);
}
Output:

Square: 25
6. Default Arguments
