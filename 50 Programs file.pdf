8. Function Overloading (Area)
C++
#include <iostream>
using namespace std;

float area(float r) {
    return 3.14 * r * r;
}

int area(int l, int b) {
    return l * b;
}

int main() {
    cout << "Circle Area: " << area(5.0) << endl;
    cout << "Rectangle Area: " << area(4, 6);
}
Output:

Circle Area: 78.5
Rectangle Area: 24
9. Sum of Array Elements
C++
#include <iostream>
using namespace std;

int sum(int arr[], int n) {
    int s = 0;
    for(int i = 0; i < n; i++)
        s += arr[i];
    return s;
}

int main() {
    int arr[] = {1,2,3,4,5};
    cout << "Sum: " << sum(arr, 5);
}
Output:

Sum: 15
10. Maximum Element in Array
C++
#include <iostream>
using namespace std;

int maxElement(int arr[], int n) {
    int max = arr[0];
    for(int i = 1; i < n; i++)
        if(arr[i] > max)
            max = arr[i];
    return max;
}

int main() {
    int arr[] = {10, 50, 30, 20};
    cout << "Maximum: " << maxElement(arr, 4);
}
Output:

Maximum: 50
11. Class and Student Details
C++
#include <iostream>
using namespace std;

class Student {
public:
    int id;
    string name;

